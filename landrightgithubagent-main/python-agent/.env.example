# Landright GitHub agent (Python). Copy to .env in this directory.
# Run from python-agent: uvicorn main:app --reload --port 4000

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# GitHub — pick one (or both; App is used when repo has the app installed):
#
# Option A: Personal Access Token (for your account or a bot user)
#   Create at: GitHub → Settings → Developer settings → Personal access tokens (classic).
#   Scopes: repo (full control).
#GITHUB_TOKEN=ghp_...
#
# Option B: GitHub App (landright bot) — use App ID + Private key, NOT Client ID/Secret.
#   App ID: this repo’s GitHub App page → "About" (e.g. 2958661).
#   Private key: same app page → "Private keys" → Generate private key → download .pem.
#   Paste PEM below (escape newlines as \n) or set GITHUB_APP_PRIVATE_KEY_PATH to the .pem path.
GITHUB_APP_ID=2958661
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/landright.private-key.pem

# Set after first export: create repo from Landright, then set owner/repo here (e.g. ibrahim-ansari-code/my-landing)
GITHUB_REPO_FULL_NAME=owner/repo

# Optional: cron and sync
# CTA_THRESHOLD=50  (fallback when LLM judge fails; run adjust when best_clicks - second >= this)
# CRON_INTERVAL_SECONDS=5  (default 5; poll Supabase every N seconds)
# MAX_ADJUST_COMMITS_PER_WINDOW=3
# ADJUST_COMMIT_WINDOW_SECONDS=3600
# REPO_ALLOW_LIST=owner/repo1,owner/repo2
# SYNC_AGENT_API_KEY=your-secret
# EXPERIENCE_LIBRARY_CTA_PATH=experience_library_cta.json
# EXPERIENCE_LIBRARY_DATA_ANALYST_PATH=experience_library_data_analyst.json
